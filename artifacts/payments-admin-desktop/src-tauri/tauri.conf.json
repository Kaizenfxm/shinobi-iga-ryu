{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-v2-schema/refs/heads/main/tauri.conf.json",
  "productName": "Shinobi Pagos Admin",
  "version": "1.0.4",
  "identifier": "com.shinobiIgaRyu.payments-admin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Shinobi Iga Ryu — Admin Pagos",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Kaizenfxm/shinobi-iga-ryu/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzQjRGRDhENzczMDlFMUYKUldRZm5qQjNqZjIwUTJzRWdTV2FzYXZqWW9xdDRTNFNaSWxpU2FneUVqSEZ3UmNJVXNTUXZ2S1oK"
    }
  }
}
